APP_NAME=The Tech Project Admin Backend
APP_ENV=development
API_V1_PREFIX=/api/v1
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=local-access-key
AWS_SECRET_ACCESS_KEY=local-secret-key
DYNAMODB_ENDPOINT_URL=
S3_BUCKET_NAME=the-tech-project-assets

JWT_SECRET_KEY=change-me
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=2880
DATA_ENCRYPTION_SECRET=change-me

ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/gif
MAX_FILE_SIZE_MB=10
LOCAL_ASSET_DIR=storage/assets

SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=Tech@1234
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=superadmin@thetechproject.com

APP_NAME=The Tech Project Admin Backend
APP_ENV=development
API_V1_PREFIX=/api/v1

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=local-access-key
AWS_SECRET_ACCESS_KEY=local-secret-key
DYNAMODB_ENDPOINT_URL=
S3_BUCKET_NAME=the-tech-project-assets

JWT_SECRET_KEY=change-me
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=2880

ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/gif
MAX_FILE_SIZE_MB=10
LOCAL_ASSET_DIR=storage/assets

ADMIN_SEED_EMAIL=admin@thetechproject.local
ADMIN_SEED_PASSWORD=Admin@123
ADMIN_SEED_NAME=Platform Admin
